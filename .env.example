# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Google Sheets (service account) - se comparte entre todos los grupos
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# La private key tiene saltos de linea reales en el JSON original.
# Pegala aca con \n literales (dos caracteres: barra + n), env.js los convierte a saltos de linea reales.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Grupos familiares: cada uno con su propia planilla y sus propios numeros de WhatsApp.
# Todas las planillas deben estar compartidas con GOOGLE_SERVICE_ACCOUNT_EMAIL (permiso Editor)
# y tener una hoja llamada "Gastos" con los encabezados: Fecha, Persona, Monto, Categoria, Descripcion, Mensaje Original, Moneda
# El campo "password" es opcional: si se define, el dashboard pide esa contrasena antes de mostrar
# los gastos de ese grupo (proteccion basica para que una familia no vea los gastos de otra).
GRUPOS_JSON={"familia1":{"nombre":"Mi familia","password":"clave1","spreadsheetId":"ID_DE_LA_SHEET_1","personas":{"whatsapp:+5491100000000":"Federico","whatsapp:+5491100000001":"Pareja"}},"familia2":{"nombre":"Familia del hermano","password":"clave2","spreadsheetId":"ID_DE_LA_SHEET_2","personas":{"whatsapp:+5491100000002":"Hermano","whatsapp:+5491100000003":"Cunada"}}}

# App
PORT=3000
NODE_ENV=development
VALIDATE_TWILIO_SIGNATURE=false
PUBLIC_BASE_URL=http://localhost:3000
