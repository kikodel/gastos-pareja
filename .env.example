# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Google Sheets (service account)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# La private key tiene saltos de linea reales en el JSON original.
# Pegala aca con \n literales (dos caracteres: barra + n), env.js los convierte a saltos de linea reales.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Mapeo de numero de WhatsApp (formato "whatsapp:+549...") a nombre de persona
PERSONAS_MAP={"whatsapp:+5491100000000":"Federico","whatsapp:+5491100000001":"Pareja"}

# App
PORT=3000
NODE_ENV=development
VALIDATE_TWILIO_SIGNATURE=false
PUBLIC_BASE_URL=http://localhost:3000
